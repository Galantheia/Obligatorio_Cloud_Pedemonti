# Puerto donde corre la app Node/Express
PORT=3000

# Datos de conexion a la base de datos MySQL (RDS)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL=false

# Grupos disponibles para mostrar productos.
# La app elige uno aleatorio por visitante y lo guarda en cookie.
PRODUCT_GROUPS="gadgets,home_office,smart_home"

# Fallback local si no estás en EC2.
LOCAL_INSTANCE_ID="local-dev"