# Puerto donde corre la app Node/Express
PORT=3000

# Configuracion de MySQL
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL=false

# Grupos disponibles para mostrar productos
PRODUCT_GROUPS="gadgets,home_office,smart_home"

# Fallback local si no estas en EC2
LOCAL_INSTANCE_ID="local-dev"

# Se usa para firmar la cookie de sesion del panel admin
SESSION_SECRET=""
